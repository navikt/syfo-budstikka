#!/usr/bin/env bash
set -euo pipefail

topic="${KAFKA_FORMIDLING_TOPIC:-team-esyfo.formidling.v1}"
scenario="${1:-brukervarsel}"

case "$scenario" in
  brukervarsel)
    event_id="$(uuidgen | tr '[:upper:]' '[:lower:]')"
    payload="{\"eventId\":\"$event_id\",\"referanse\":\"ref-test-1\"}"
    ;;

  duplikat)
    payload='{"eventId":"a0000000-0000-0000-0000-000000000001","referanse":"ref-test-1"}'
    ;;

  poison)
    payload='ikke-json'
    ;;

  mangler-event-id)
    payload='{"referanse":"ref-test-uten-event-id"}'
    ;;

  tom-payload)
    payload=''
    ;;

  *)
    echo "Usage: mise run kafka:send <scenario>"
    echo
    echo "Scenarios:"
    echo "  brukervarsel"
    echo "  duplikat"
    echo "  poison"
    echo "  mangler-event-id"
    echo "  tom-payload"
    exit 1
    ;;
esac

printf '%s\n' "$payload" |
docker-compose -f docker-compose.yaml -f docker-compose.kafka.yaml exec -T kafka \
  /opt/kafka/bin/kafka-console-producer.sh \
  --bootstrap-server localhost:19092 \
  --topic "$topic"

echo "Sent '$scenario' to '$topic'"
