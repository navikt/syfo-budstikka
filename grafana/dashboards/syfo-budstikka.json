          "placement": "bottom"
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      },
      "targets": [
        {
          "expr": "sum(rate(inbox_message_processed_total[5m]))",
          "legendFormat": "processed",
          "refId": "A"
